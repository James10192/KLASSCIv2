{
    "name": "esbtp/esbtp-yakro-v2",
    "type": "project",
    "description": "Système de gestion d'école ESBTP YAKRO - Version 2",
    "keywords": [
        "laravel",
        "school-management",
        "esbtp",
        "yakro"
    ],
    "license": "MIT",
    "require": {
        "php": "^7.4|^8.0|^8.1|^8.2",
        "barryvdh/laravel-dompdf": "^2.0",
        "doctrine/dbal": "^3.0",
        "fruitcake/laravel-cors": "^3.0",
        "google-gemini-php/laravel": "^2.0",
        "guzzlehttp/guzzle": "^7.2",
        "jenssegers/agent": "^2.6",
        "laravel-notification-channels/webpush": "^8.0",
        "laravel/framework": "^9.0|^10.0",
        "laravel/sanctum": "^3.0",
        "laravel/tinker": "^2.7",
        "laravel/ui": "^4.0",
        "maatwebsite/excel": "^3.1",
        "mpdf/mpdf": "^8.2",
        "owen-it/laravel-auditing": "^13.0",
        "setasign/fpdf": "^1.8",
        "setasign/fpdi": "^2.6",
        "spatie/browsershot": "^5.0",
        "spatie/laravel-permission": "^5.0"
    },
    "require-dev": {
        "fakerphp/faker": "^1.9.1",
        "laravel/pint": "^1.0",
        "laravel/sail": "^1.18",
        "mockery/mockery": "^1.4.4",
        "nunomaduro/collision": "^6.0",
        "phpunit/phpunit": "^9.5.10",
        "spatie/laravel-ignition": "^1.0"
    },
    "autoload": {
        "psr-4": {
            "App\\": "app/",
            "Database\\Factories\\": "database/factories/",
            "Database\\Seeders\\": "database/seeders/"
        },
        "files": [
            "app/helpers.php"
        ]
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    },
    "scripts": {
        "post-autoload-dump": [
            "Illuminate\\Foundation\\ComposerScripts::postAutoloadDump",
            "@php artisan package:discover --ansi"
        ],
        "post-update-cmd": [
            "@php artisan vendor:publish --tag=laravel-assets --ansi --force"
        ],
        "post-root-package-install": [
            "@php -r \"file_exists('.env') || copy('.env.example', '.env');\""
        ],
        "post-create-project-cmd": [
            "@php artisan key:generate --ansi"
        ]
    },
    "extra": {
        "laravel": {
            "dont-discover": []
        }
    },
    "config": {
        "optimize-autoloader": true,
        "preferred-install": "dist",
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true,
            "php-http/discovery": true
        },
        "audit": {
            "ignore": {
                "PKSA-2cx9-ynrq-qdk3": "Dépendance indirecte via laravel/framework. league/commonmark non utilisé pour parser du contenu utilisateur. DoS non applicable.",
                "PKSA-4s4z-t146-6123": "psy/psysh est une dépendance de laravel/tinker, non utilisé en production. Vecteur local non applicable."
            }
        }
    },
    "minimum-stability": "dev",
    "prefer-stable": true
}
