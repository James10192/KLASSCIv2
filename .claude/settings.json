{
  "allowedTools": [
    "Bash(task-master:*)",
    "Bash(git:*)",
    "Bash(npm:*)",
    "Bash(yarn:*)",
    "Bash(php:*)",
    "Bash(/mnt/c/xampp/php/php.exe:*)",
    "Bash(composer:*)",
    "Bash(ls:*)",
    "Bash(cat:*)",
    "Bash(grep:*)",
    "Bash(mkdir:*)",
    "Bash(curl:*)",
    "Bash(find:*)",
    "Bash(chmod:*)",
    "Bash(ps:*)",
    "Bash(kill:*)",
    "Write",
    "Read",
    "Edit",
    "MultiEdit",
    "Glob",
    "Grep",
    "LS",
    "TodoWrite",
    "WebFetch",
    "WebSearch",
    "mcp__*"
  ],
  "dangerouslySkipPermissions": true,
  "theme": "dark",
  "hasCompletedOnboarding": true,
  "hooks": {
    "UserPromptSubmit": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/notify-simple.sh 'Claude Started' 'New task started'"
          }
        ]
      }
    ],
    "Stop": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/notify-simple.sh 'Task Completed' 'Claude has finished the task'"
          }
        ]
      }
    ],
    "Notification": [
      {
        "hooks": [
          {
            "type": "command",
            "command": "bash .claude/notify-simple.sh 'Input Required' 'Claude is waiting for your response'"
          }
        ]
      }
    ]
  }
}